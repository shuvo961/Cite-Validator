PORT=3000
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=change-this-before-production

# Optional Google login. If these are empty, /auth/google falls back to local demo login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated admin emails. These users become admins after login.
ADMIN_EMAILS=you@example.com

# Local demo login defaults.
DEMO_USER_EMAIL=demo@citevalidator.local

# Optional but recommended for polite Crossref/OpenAlex requests.
CONTACT_EMAIL=you@example.com

# Optional API keys. The MVP works without them and skips key-only features.
SEMANTIC_SCHOLAR_API_KEY=
NCBI_API_KEY=

# Comma-separated allowlist for production CORS, e.g. https://your-app.example
CORS_ORIGINS=
